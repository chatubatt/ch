	measure 'Horário Mais Ligações' = ```
			
			VAR VolumePorIntervalo =
			    SUMMARIZE(
			        '!DIM_CALENDARIO',
			        '!DIM_CALENDARIO'[Intervalo Hora],
			        "TotalRecebidas", 
			        [RECEBIDAS]
			    )
			VAR IntervaloComMaiorVolume = 
			    TOPN(1, VolumePorIntervalo, [TotalRecebidas], DESC)
			RETURN
			    MAXX(IntervaloComMaiorVolume, '!DIM_CALENDARIO'[Intervalo Hora])
			```
		displayFolder: Telefonia
		lineageTag: 5d7c55d8-0925-4368-809a-7887bcf0b2e8

	measure 'Dia da Semana Mais Ligações' = ```
			
			VAR VolumePorIntervalo =
			    SUMMARIZE(
			        '!DIM_CALENDARIO',
			        '!DIM_CALENDARIO'[Dia da Semana],
			        "TotalRecebidas", 
			        [RECEBIDAS]
			    )
			VAR IntervaloComMaiorVolume = 
			    TOPN(1, VolumePorIntervalo, [TotalRecebidas], DESC)
			RETURN
			    MAXX(IntervaloComMaiorVolume, '!DIM_CALENDARIO'[Dia da Semana])
