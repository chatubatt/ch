			    FILTER(
			        SUMMARIZE(
			            '!DIM_CALENDARIO',
			            '!DIM_CALENDARIO'[Date],
			            '!DIM_CALENDARIO'[Dia da Semana]
			        ),
			        [RECEBIDAS] > 0
			    )
