	measure 'ABANDONADAS até 5s' =
			
			
			VAR ABN = CALCULATE(SUM(GENESYS_FT_ABANDONADAS[ABANDONADAS]),GENESYS_FT_ABANDONADAS[ABANDON_TIME] <= 5)
			
			RETURN
			
			IF(ABN=0, BLANK(), ABN)
		displayFolder: Telefonia
		lineageTag: 913e78fb-2455-4924-8fad-e168e0bb4ebe

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ABANDONADAS até 10s' =
			
			
			VAR ABN = CALCULATE(SUM(GENESYS_FT_ABANDONADAS[ABANDONADAS]),GENESYS_FT_ABANDONADAS[ABANDON_TIME] > 5 && GENESYS_FT_ABANDONADAS[ABANDON_TIME] <= 10)
			
			RETURN
			
