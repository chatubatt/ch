table !Medidas
	lineageTag: 48ad387a-7da0-4a39-962d-45a26ab2282a

	measure Atualização =
			//"Atualizado em: " & SELECTEDVALUE('Dim_Atualização'[Data e Hora Certa]) & ", com dados até: " & MAX(SUA TABELA)
			
			"Atualizado em: " & SELECTEDVALUE('!DIM_ATUALIZAÇÃO'[Data e Hora Certa]) & ", com dados até: " & CALCULATE(MAX('@FT_FORECAST'[Data]), '!DIM_CALENDARIO'[Intervalo_Status] = 1, REMOVEFILTERS())
		displayFolder: Atualização
		lineageTag: 1795c91e-a257-412b-a497-bd8ed9337c7c

	measure ATENDIDAS =
			
			
			VAR GENESYS = SUM(GENESYS_FT_ATENDIDAS[ATENDIDAS])
			
			RETURN
			
			GENESYS
		formatString: 0
		displayFolder: Telefonia
		lineageTag: 4bc9fc38-539f-4a3e-a9ab-43b6c7f879bf

	measure TRANSFERIDAS = SUM(GEESYS_FT_TRANSFERIDAS[TOTAL])
		formatString: 0
		displayFolder: Telefonia
		lineageTag: c12b18bf-3ae3-404d-8b0a-0db45c68e2cb

		annotation PBI_FormatHint = {"isDecimal":true}

	measure ABANDONADAS =
			
			
			VAR ABN = SUM(GENESYS_FT_ABANDONADAS[ABANDONADAS])
			
			RETURN
			
			IF(ABN=0,BLANK(),ABN)
		formatString: 0
		displayFolder: Telefonia
		lineageTag: 9ef906be-c0cf-45df-a221-a96d1296853f

		annotation PBI_FormatHint = {"isDecimal":true}

	measure RECEBIDAS =
			
			
			VAR RECEBIDAS = SUM(GENESYS_FT_RECEBIDAS[RECEBIDAS])
			
			RETURN
			
			IF(RECEBIDAS = 0, BLANK(), RECEBIDAS)
		formatString: 0
		displayFolder: Telefonia
		lineageTag: f0b1a906-c8f7-4a82-9aa3-213b25568d9d

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'NS Realizado' =
			
			
			VAR ATENDIDAS_NIVEL = [Atendidas no Nível 20s]
			VAR RECEBIDAS = [RECEBIDAS]
			VAR ABN_20 = [ABANDONADAS até 20s Total]
			
			
			RETURN
			
			DIVIDE(ATENDIDAS_NIVEL,(RECEBIDAS - ABN_20), BLANK())
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Telefonia
		lineageTag: 66335235-1bd9-4dc2-9d5d-2f3aa285c881

	measure TMA =
			
			
			VAR TMA = SUM('GENESYS_FT_FINALIZADAS'[TALK_COMPLETE_TIME])
			VAR atendidas = SUM('GENESYS_FT_FINALIZADAS'[FINALIZADAS])
			VAR calculo = DIVIDE(TMA, ATENDIDAS, BLANK())
			
			RETURN
			    calculo
		formatString: 0
		displayFolder: Telefonia
		lineageTag: ae314a0a-e484-4a4e-8d50-cb633e6f4222

		annotation PBI_FormatHint = {"isDecimal":true}

	measure ContaPA = ```
			
			
			VAR TL = SUM(GENESYS_FT_PAUSAS[Tempo_total])
			
			RETURN  
			
			DIVIDE(TL,1800,BLANK())
			```
		displayFolder: Tempos
		lineageTag: bdacdde9-f6a6-4925-9fd4-db15961e9aad

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure ContaPA_Max = ```
			
			
			VAR MAXIMO = MAX(GENESYS_FT_PAUSAS[CONTA PA])
			
			RETURN
			
			MAXIMO
			
			```
		formatString: 0
		displayFolder: Tempos
		lineageTag: 8ee1291b-b728-4cd8-bd30-95259c1bd0db

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Atendidas no Nível 20s' = ```
			
			
			VAR GENESYS = CALCULATE(SUM(GENESYS_FT_ATENDIDAS[ATENDIDAS]),GENESYS_FT_ATENDIDAS[ANSWERED_TIME] <= 20)
			
			RETURN
			
			GENESYS
			
			```
		formatString: 0
		displayFolder: Telefonia
		lineageTag: 5151db96-c7f3-4b3b-a0e1-3408e9aa1041

	measure TMO =
			
			
			VAR TMO = SUM(GENESYS_FT_FINALIZADAS[TEMPO_OPERACIONAL])
			VAR ATENDIDAS = SUM(GENESYS_FT_FINALIZADAS[FINALIZADAS])
			
			RETURN
			
			DIVIDE( TMO, ATENDIDAS, BLANK())
		formatString: 0
		displayFolder: Telefonia
		lineageTag: 993e2a91-d4da-4aa7-b635-ed4dd351d6c0

	measure TME =
			
			
			VAR TME = SUM(GENESYS_FT_ATENDIDAS[ANSWERED_TIME])
			VAR ATENDIDAS = [ATENDIDAS]
			
			RETURN
			
			DIVIDE( TME, ATENDIDAS, BLANK())
		formatString: 0
		displayFolder: Telefonia
		lineageTag: 437022eb-9a5a-4386-8319-d29cb6587c79

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'ABANDONADAS até 20s Total' =
			
			
			VAR ABN = CALCULATE(SUM(GENESYS_FT_ABANDONADAS[ABANDONADAS]),GENESYS_FT_ABANDONADAS[ABANDON_TIME] <= 20)
			
			RETURN
			
			IF(ABN=0, BLANK(), ABN)
		formatString: 0
		displayFolder: Telefonia
		lineageTag: 0c27fbc3-1188-461e-a511-1ee064be06f2

		annotation PBI_FormatHint = {"isDecimal":true}

	measure %ABANDONADAS = DIVIDE([ABANDONADAS], [RECEBIDAS], BLANK())
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Telefonia
		lineageTag: 1d89b687-1602-4c7b-bab4-ef65da8306bf

	measure Trafego =
			
			
			--[ATENDIDAS] * [TMO] + [ABANDONADAS] * [TMABN]
			
			[RECEBIDAS] * [TMO]
		formatString: 0
		displayFolder: Telefonia
		lineageTag: ada682de-8737-42bb-8365-b56ad5758132

		annotation PBI_FormatHint = {"isDecimal":true}

	measure %ATENDIDO = DIVIDE([ATENDIDAS],[RECEBIDAS], BLANK())
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Telefonia
		lineageTag: d4fd3ffc-dd68-40b1-987d-4c5cbff6af95

	measure 'Tempo Logado' = ```
			
			VAR TL = SUM(GENESYS_FT_PAUSAS[Tempo_total])
			
			VAR T =   TL
			VAR H =   INT(T/3600)
			VAR M =   INT((T - (H * 3600))/60)  
			VAR S =   MOD(t,60)
			VAR vresultado = H * 10000 + M * 100 + S //VALUE(H & M & S)
			RETURN
			 
			vresultado
			
			```
		formatString: 00:00:00
		displayFolder: Tempos
		lineageTag: d288af86-ffcf-43dc-9255-a9b81988bc45

		annotation PBI_FormatHint = {"isCustom":true}

	measure 'Pausa Total' = ```
			
			
			VAR PAUSAS = SUM(GENESYS_FT_PAUSAS[Pausa]) +  SUM(GENESYS_FT_PAUSAS[Lanche]) +  SUM(GENESYS_FT_PAUSAS[Treinamento])
			
			VAR T = PAUSAS   
			VAR H =   INT(T/3600)
			VAR M =   INT((T - (H * 3600))/60)  
			VAR S =   MOD(t,60)
			VAR vresultado = H * 10000 + M * 100 + S //VALUE(H & M & S)
			RETURN
			 
			vresultado
			```
		formatString: 00:00:00
		displayFolder: Tempos
		lineageTag: 42732193-d7bf-408e-ad9a-991106ca8170

		annotation PBI_FormatHint = {"isCustom":true}

	measure 'Tempo Produtivo' = ```
			
			
			-- TEMPOS GENESYS
			VAR TEMPO_LOGADO = SUM(GENESYS_FT_PAUSAS[Tempo_total])
			VAR TEMPO_PAUSAS = SUM(GENESYS_FT_PAUSAS[Pausa]) +  SUM(GENESYS_FT_PAUSAS[Lanche]) +  SUM(GENESYS_FT_PAUSAS[Treinamento])
			
			VAR TEMPO_PRODUTIVO = TEMPO_LOGADO - TEMPO_PAUSAS
			VAR T =   TEMPO_PRODUTIVO
			VAR H =   INT(T/3600)
			VAR M =   INT((T - (H * 3600))/60)  
			VAR S =   MOD(t,60)
			VAR vresultado = H * 10000 + M * 100 + S //VALUE(H & M & S)
			RETURN
			 
			vresultado
			```
		formatString: 00:00:00
		displayFolder: Tempos
		lineageTag: 960a4197-ed21-4410-8bf0-a54b5ea7b396

		annotation PBI_FormatHint = {"isCustom":true}

	measure 'Carga HC' = 22800
		formatString: 0
		displayFolder: Tempos
		lineageTag: d4418ce3-083b-4707-891a-ed5cea432e8d

	measure 'HC Bruto Real Total' =
			
			
			VAR HC = MAXX(GENESYS_FT_PAUSAS, [HC Bruto Real])
			
			// Calcular a razão em relação à carga
			VAR Carga_HC = [Carga HC]
			
			RETURN DIVIDE(HC, Carga_HC, BLANK())
		formatString: 0
		displayFolder: Tempos
		lineageTag: 8592d18b-ecc5-4969-a4f9-bd0ab4573533

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'HC Liquido Real' =
			
			
			VAR HC = MAXX(GENESYS_FT_PAUSAS, [HC_Liq_Real])
			
			// Calcular a razão em relação à carga
			VAR Carga_HC = [Carga HC]
			
			RETURN DIVIDE(HC, Carga_HC, BLANK())
		formatString: 0
		displayFolder: Tempos
		lineageTag: 4ac88930-d39c-4a7a-8cef-9f88b38aa59e

		annotation PBI_FormatHint = {"isDecimal":true}

	measure TMABN =
			
			
			VAR TMABN = SUM(GENESYS_FT_ABANDONADAS[TEMPO_ABANDONO])
			VAR ABANDONADAS = [ABANDONADAS]
			
			RETURN
			
			DIVIDE( TMABN, ABANDONADAS, BLANK())
		formatString: 0
		displayFolder: Telefonia
		lineageTag: a076bf18-6314-4159-a298-789d9131027e

		annotation PBI_FormatHint = {"isDecimal":true}

	measure '% POCC' =
			
			VAR TrafficInDays = [Trafego]/86400
			VAR AvailableTimeInDays = SUMX(GENESYS_FT_PAUSAS, GENESYS_FT_PAUSAS[Tempo_total] - (GENESYS_FT_PAUSAS[Pausa] + GENESYS_FT_PAUSAS[Lanche] + GENESYS_FT_PAUSAS[Treinamento]))/86400
			VAR RawPercentage = DIVIDE(TrafficInDays, AvailableTimeInDays, 0)
			RETURN
			    IF(RawPercentage > 1, 1, RawPercentage)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Tempos
		lineageTag: b5bfbe47-e6c2-4ef2-9775-f631287a36e0

	measure 'Pausa NR' = ```
			
			
			VAR NR = SUM(GENESYS_FT_PAUSAS[Pausa]) +  SUM(GENESYS_FT_PAUSAS[Lanche])
			
			VAR T =   NR
			VAR H =   INT(T/3600)
			VAR M =   INT((T - (H * 3600))/60)  
			VAR S =   MOD(t,60)
			VAR vresultado = H * 10000 + M * 100 + S //VALUE(H & M & S)
			RETURN
			 
			vresultado
			```
		formatString: 00:00:00
		displayFolder: Tempos
		lineageTag: 22fc4bdd-0bf2-4ee3-81f6-369e0fe0abb6

		annotation PBI_FormatHint = {"isCustom":true}

	measure @RECEBIDAS =
			
			
			VAR A = SUM('@FT_FORECAST'[Chamadas recebidas PREVISTO])
			
			RETURN
			IF(
			    A = 0 || ISBLANK(A),BLANK(), A
			)
		formatString: 0
		displayFolder: Forecast
		lineageTag: 23284297-4a87-432c-855d-327f90a20c88

		annotation PBI_FormatHint = {"isDecimal":true}

	measure @ATENDIDAS = ```
			
			
			
			VAR RECEBIDAS = [@RECEBIDAS]
			VAR FATOR = 0.92
			VAR A = RECEBIDAS * FATOR
			
			
			RETURN
			
			IF(A=0,BLANK(),A)
			
			```
		formatString: 0
		displayFolder: Forecast
		lineageTag: d3fe2680-3f33-4a60-a9c0-e142bdd44728

		annotation PBI_FormatHint = {"isDecimal":true}

	measure @NS = ```
			
			/*
			
			MEDIDA COMPAGAS
			
			VAR TotalPonderado = SUM('@FT_FORECAST'[Nível de Serviço POND])
			VAR VolumeProjetado = SUM('@FT_FORECAST'[Chamadas recebidas PREVISTO])
			RETURN
			IF(
			    ISBLANK(VolumeProjetado) || VolumeProjetado = 0,BLANK(),
			    DIVIDE(
			        TotalPonderado,
			        VolumeProjetado,
			        0
			    )
			)*/
			
			
			-- MEDIDA SULGAS
			VAR TotalPonderado = 
			    SUMX(
			        '@FT_FORECAST',
			        '@FT_FORECAST'[Nível de Serviço PREVISTO] * '@FT_FORECAST'[Chamadas recebidas PREVISTO]
			    )
			VAR VolumeProjetado = 
			    SUM('@FT_FORECAST'[Chamadas recebidas PREVISTO])
			RETURN
			    IF(
			        ISBLANK(VolumeProjetado) || VolumeProjetado = 0,
			        BLANK(),
			        DIVIDE(
			            TotalPonderado,
			            VolumeProjetado,
			            BLANK()
			        )
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Forecast
		lineageTag: 68c0aec8-3289-48f2-ae2b-4fd56a59753a

	measure 'Atendidas Fora do Nível 20s' = ```
			
			 
			VAR GENESYS = CALCULATE(SUM(GENESYS_FT_ATENDIDAS[ATENDIDAS]),GENESYS_FT_ATENDIDAS[ANSWERED_TIME] > 20)
			
			RETURN
			    
			GENESYS
			              
			```
		formatString: 0
		displayFolder: Telefonia
		lineageTag: 39730fb3-7cac-430f-8cd1-c6fcedf54d1b

		annotation PBI_FormatHint = {"isDecimal":true}

	measure @PA = MAX('@FT_FORECAST'[RECURSOS PREVISTOS (HC)])
		formatString: 0
		displayFolder: Forecast
		lineageTag: 61e224c6-edbe-447f-937e-7fdc25e37dfe

	measure @TRAFEGO =
			
			
			
			
			SUMX('@FT_FORECAST','@FT_FORECAST'[Chamadas recebidas PREVISTO]*'@FT_FORECAST'[TMO PREVISTO])
		formatString: 0
		displayFolder: Forecast
		lineageTag: 302fb095-348b-4726-82c8-d3c28e592848

		annotation PBI_FormatHint = {"isDecimal":true}

	measure @TMO = ```
			
			 
			VAR TotalTMO = SUM('@FT_FORECAST'[POND TMO PREVISTO])
			VAR TotalChamadas = SUM('@FT_FORECAST'[Chamadas recebidas PREVISTO])
			
			RETURN
			IF(
			    TotalChamadas = 0 || ISBLANK(TotalChamadas),
			    BLANK(),
			    DIVIDE(
			        TotalTMO,
			        TotalChamadas,
			        BLANK()
			    )
			)
			
			```
		formatString: 0
		displayFolder: Forecast
		lineageTag: 29f07a22-b4af-4b45-ba12-faa9a5601125

		annotation PBI_FormatHint = {"isDecimal":true}

	measure '@HC Líquido Previsto' =
			
			
			VAR PAsProjetados = MAX('@FT_FORECAST'[RECURSOS PREVISTOS (HC)])
			VAR CargaHC = [Carga HC]
			VAR TaxaCorrespondente = 1-(([Carga HC]*0.105263)/[Carga HC])
			
			RETURN
			PAsProjetados * TaxaCorrespondente
		formatString: 0
		displayFolder: Forecast
		lineageTag: 23c6ef74-27e0-4c93-93e2-b554d8a05537

		annotation PBI_FormatHint = {"isDecimal":true}

	measure '@HORAS CONTRATADAS' =
			
			VAR T = SUM('@FT_FORECAST'[HORA PREVISTA])*86400
			VAR H = INT(T/3600)
			VAR M = INT((T - (H * 3600))/60)
			VAR S = MOD(t,60)
			VAR vresultado = H * 10000 + M * 100 + S //VALUE(H & M & S)
			
			RETURN
			vresultado
		formatString: 00:00:00
		displayFolder: Forecast
		lineageTag: f295159a-9086-4ffa-83b1-8c4247d30de6

		annotation PBI_FormatHint = {"isCustom":true}

	measure 'ABANDONADAS Acima 20s' =
			
			
			VAR ABN = CALCULATE(SUM(GENESYS_FT_ABANDONADAS[ABANDONADAS]),GENESYS_FT_ABANDONADAS[ABANDON_TIME] > 20)
			
			RETURN
			
			IF(ABN=0, BLANK(), ABN)
		formatString: 0
		displayFolder: Telefonia
		lineageTag: 8792827d-5bae-4ba3-aad9-da752ba254dc

		annotation PBI_FormatHint = {"isDecimal":true}

	measure @PAUSAS =
			
			VAR T = [@HC Líquido Previsto]*2400
			VAR H = INT(T/3600)
			VAR M = INT((T - (H * 3600))/60)
			VAR S = MOD(t,60)
			VAR vresultado = H * 10000 + M * 100 + S //VALUE(H & M & S)
			
			RETURN
			vresultado
		formatString: 00:00:00
		displayFolder: Forecast
		lineageTag: 0a096740-6e26-434b-b76b-b5b612277d57

		annotation PBI_FormatHint = {"isCustom":true}

	measure %RECEBIDAS =
			
			VAR A = DIVIDE([RECEBIDAS],[@RECEBIDAS], BLANK()) - 1
			
			RETURN
			
			IF(ISBLANK([@RECEBIDAS]) || ISBLANK(A) || A = 0 ,BLANK(),A)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Desvio
		lineageTag: c8537b2c-8216-4967-8491-984c65c9a200

	measure %ATENDIDAS =
			
			VAR A = DIVIDE([atendidas],[@atendidas], BLANK()) - 1
			
			RETURN
			
			 SWITCH(TRUE(),
			     [@atendidas]=0 , BLANK(),A)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Desvio
		lineageTag: 86da3880-c0b4-4329-871d-da5c2c35a273

	measure %NS = ```
			
			
			   VAR A = [NS Realizado]-[@NS]
			
			   RETURN
			
			   SWITCH(TRUE(),
			    ISBLANK([NS Realizado]), BLANK(),A)
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Desvio
		lineageTag: fab3d74e-ff86-4098-8d85-50ecf58c8457

	measure %PA =
			
			
			VAR A = DIVIDE([ContaPA_Max],[@PA],BLANK())-1
			
			RETURN
			
			 SWITCH(TRUE(),
			    ISBLANK([@PA]), BLANK(),A)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Desvio
		lineageTag: c800fdea-4b1d-4023-bed0-b26b3241aeb5

	measure %TRAFEGO =
			
			
			VAR A = DIVIDE([Trafego],[@TRAFEGO],BLANK())-1
			
			RETURN
			
			 SWITCH(TRUE(),
			    ISBLANK([@TRAFEGO]), BLANK(),A)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Desvio
		lineageTag: 69b521d7-4936-47a0-aa42-fe4a052a2d99

	measure %TMO =
			
			
			VAR A = DIVIDE([TMO],[@TMO],BLANK())-1
			
			RETURN
			
			 SWITCH(TRUE(),
			    ISBLANK([@TMO]), BLANK(),A)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Desvio
		lineageTag: f3dfffee-af80-454f-a032-c45bc20784c4

	measure %HC =
			
			
			VAR A = DIVIDE([HC Liquido Real],[@HC Líquido Previsto],BLANK())-1
			
			RETURN
			
			 SWITCH(TRUE(),
			    ISBLANK([@HC Líquido Previsto]), BLANK(),A)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Desvio
		lineageTag: f73f45ac-ac43-4041-b710-5793a05161a2

	measure '%Tempo Logado' =
			
			
			VAR TEMPO_LOGADO = SUM(GENESYS_FT_PAUSAS[Tempo_total])
			VAR A = DIVIDE(TEMPO_LOGADO,SUM('@FT_FORECAST'[HORA PREVISTA])*86400,BLANK())-1
			
			RETURN
			
			 SWITCH(TRUE(),
			    ISBLANK([@HORAS CONTRATADAS]), BLANK(),A)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Desvio
		lineageTag: c3627589-1ed4-4318-9f96-4bb67d8ca4d6

	measure '%Tempo Produtivo' =
			
			
			VAR TEMPO_LOGADO = SUM(GENESYS_FT_PAUSAS[Tempo_total])
			VAR TEMPO_PAUSAS = SUM(GENESYS_FT_PAUSAS[Pausa]) +  SUM(GENESYS_FT_PAUSAS[Lanche]) +  SUM(GENESYS_FT_PAUSAS[Treinamento])
			
			
			VAR TEMPO_PRODUTIVO = TEMPO_LOGADO - TEMPO_PAUSAS
			VAR A = DIVIDE(TEMPO_PRODUTIVO, TEMPO_LOGADO,BLANK())-1
			
			RETURN
			
			 SWITCH(TRUE(),   ISBLANK([Tempo Logado]), BLANK(),A)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Desvio
		lineageTag: a04a99df-acc4-497e-aa24-d283c1b78fac

	measure %PAUSA =
			
			
			VAR TEMPO_LOGADO = SUM(GENESYS_FT_PAUSAS[Tempo_total])
			VAR TEMPO_PAUSAS = SUM(GENESYS_FT_PAUSAS[Pausa]) +  SUM(GENESYS_FT_PAUSAS[Lanche]) +  SUM(GENESYS_FT_PAUSAS[Treinamento])
			
			
			VAR TEMPO_PRODUTIVO = TEMPO_LOGADO - TEMPO_PAUSAS
			VAR A = DIVIDE(TEMPO_PAUSAS, TEMPO_LOGADO,BLANK())-1
			
			RETURN
			
			 SWITCH(TRUE(),
			    ISBLANK([Tempo Logado]), BLANK(),A)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Desvio
		lineageTag: 12a7aa60-fa0b-4f88-abe6-58ca8053098c

	measure '%Variação Abandono' = ```
			
			
			var a = [%ABANDONADAS] - 0.05
			
			RETURN
			
			IF([%ABANDONADAS]=0, BLANK(),a)
			
			```
		displayFolder: Desvio
