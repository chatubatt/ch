table !DIM_CALENDARIO
	lineageTag: 24b45afd-6692-41c8-9850-e5048c6fdbb7

	column Data
		formatString: General Date
		lineageTag: 43a78039-aeb7-4671-b5b6-cb03c7a680c0
		summarizeBy: none
		sourceColumn: [Value]

		variation Variation
			isDefault
			relationship: 31c55c64-6965-478d-883a-c0f0d9db9474
			defaultHierarchy: LocalDateTable_510334bd-ac5e-47af-8916-10018eb93124.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

	column CHAVE_INTERVALO = FORMAT('!DIM_CALENDARIO'[Data],"DD/MM/YYYY HH:MM:SS")
		lineageTag: 5a809c62-0d88-4532-bcf3-b416e0c87aef
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column AnoMêsSerial =
			
			VAR DataAtual = '!DIM_CALENDARIO'[Data]
			VAR Ano = YEAR(DataAtual)
			VAR Mes = MONTH(DataAtual)
			VAR Dia = DAY(DataAtual)
			RETURN
			    IF(Dia >= 21,
			        IF(Mes = 12, (Ano + 1) * 100, Ano * 100) + IF(Mes = 12, 1, Mes + 1),  // Se for dia >= 21, usa o próximo mês
			        Ano * 100 + Mes  // Se for dia < 21, usa o mês atual
			    )
		formatString: 0
		lineageTag: 6ce172a8-5498-4916-bc7b-b2d954796df6
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Nome do Mês/Ano' = ```
			
			VAR DataAtual = '!DIM_CALENDARIO'[Data]
			VAR Ano = YEAR(DataAtual)
			VAR Mes = MONTH(DataAtual)
			VAR Dia = DAY(DataAtual)
			VAR MesAjustado = IF(Dia >= 21, IF(Mes = 12, 1, Mes + 1), Mes) // Ajusta o mês conforme a lógica
			VAR AnoAjustado = IF(Dia >= 21, IF(Mes = 12, Ano + 1, Ano), Ano) // Ajusta o ano conforme a lógica
			RETURN
			    UPPER(LEFT(FORMAT(DATE(AnoAjustado, MesAjustado, 1), "mmm") & "/" & AnoAjustado, 1)) & 
			    RIGHT(FORMAT(DATE(AnoAjustado, MesAjustado, 1), "mmm") & "/" & AnoAjustado, 7)
			```
		lineageTag: 657b35ba-bb38-4002-b13a-4c6abccec40e
		summarizeBy: none
		sortByColumn: AnoMêsSerial

		annotation SummarizationSetBy = Automatic

	column 'Mês Atual' = ```
			VAR DataAtual = TODAY()
			VAR Ano = YEAR(DataAtual)
			VAR Mes = MONTH(DataAtual)
			VAR Dia = DAY(DataAtual)
			var AnoMesAtual = 
			    IF(Dia >= 21,
			        IF(Mes = 12, (Ano + 1) * 100, Ano * 100) + IF(Mes = 12, 1, Mes + 1),  // Se for dia >= 21, usa o próximo mês
			        Ano * 100 + Mes  // Se for dia < 21, usa o mês atual
			    )
			RETURN
			
			IF(AnoMesAtual = '!DIM_CALENDARIO'[AnoMêsSerial], "Mês Atual", '!DIM_CALENDARIO'[Nome do Mês/Ano])
			
			
			```
		lineageTag: e071e057-13f0-4588-ac24-f9203a0cfc02
		summarizeBy: none
		sortByColumn: AnoMêsSerial

		annotation SummarizationSetBy = Automatic

	column Intervalo_Atual = ```
			
			var HoraAtual = MAX('!DIM_ATUALIZAÇÃO'[Data e Hora Certa])
			var MinutosAtual = MINUTE(HoraAtual)
			var intervalo_atual =   IF(
			        MinutosAtual < 30,
			        DATE(YEAR(HoraAtual), MONTH(HoraAtual), DAY(HoraAtual)) + TIME(HOUR(HoraAtual) - 1, 0, 0),  -- PARA FILTRAR 1 HR ANTES DO INTERVALO DE ATUALIZAÇÃO
			        DATE(YEAR(HoraAtual), MONTH(HoraAtual), DAY(HoraAtual)) + TIME(HOUR(HoraAtual) - 1, 30, 0))
			
			return
			  
			  intervalo_atual
			
			
			
			
			```
		formatString: General Date
		lineageTag: 4392ac70-dcf0-4407-8651-3943da7d1e7e
		summarizeBy: none

		variation Variation
			isDefault
			relationship: f536a8fc-9589-4167-82bb-6e5be5cb5694
			defaultHierarchy: LocalDateTable_c973e6b6-aa1e-422b-9cb2-36add80ee836.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

	column Date = FORMAT('!DIM_CALENDARIO'[Data], "dd/mm/yyyy")
		dataType: dateTime
		formatString: Short Date
		lineageTag: 23d49220-ed9e-4b00-99ad-e77f952eb565
		summarizeBy: none

		variation Variation
			isDefault
			relationship: d4b75660-d364-4533-acba-f83b03928da8
			defaultHierarchy: LocalDateTable_3174d85b-71c6-4c5b-b863-a8e2790f785b.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column Periodo = ```
			
			
			var hora = HOUR('!DIM_CALENDARIO'[Data]) RETURN 
			
			SWITCH( TRUE(),
			        hora < 6, "Madrugada",
			        hora < 12, "Manhã",
			        hora < 18, "Tarde",
			        "Noite")
			        
			
			
			
			```
		lineageTag: 29708ac8-e6dc-405a-a93a-56d293a82398
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Intervalo = HOUR('!DIM_CALENDARIO'[Data])*100+MINUTE('!DIM_CALENDARIO'[Data])
		formatString: 00:00
		lineageTag: 0b6d4764-8044-4713-9f12-306c1b078277
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isCustom":true}

	column Intervalo_Status = ```
			
			
			VAR intervalo = '!DIM_CALENDARIO'[Intervalo_Atual] 
			
			RETURN 
			
			SWITCH(TRUE(),
			    intervalo >= '!DIM_CALENDARIO'[Data],1,
			    0
			)
			
			```
		formatString: 0
		lineageTag: 7e88988b-a8ba-44b9-9012-50c5b428421a
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Dia_Atual = ```
			
			var HoraAtual = NOW()
			var DiaAtual = DATE(YEAR(HoraAtual), MONTH(HoraAtual), DAY(HoraAtual))
			return
			  
			  SWITCH( TRUE(),
			  '!DIM_CALENDARIO'[Date] = DiaAtual, 1,0)
			```
		formatString: 0
		lineageTag: 551b116d-822c-4a9e-bfe5-f6e52abe49b1
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Intervalo Hora' =
			
			VAR DataInicio = '!DIM_CALENDARIO'[chave_intervalo]
			VAR HoraInicio = HOUR(DataInicio)
			VAR HoraFim = if( HoraInicio = 23, 0, HoraInicio + 1)
			
			RETURN
			    FORMAT(HoraInicio, "00") & ":00:00" & " às " & FORMAT(HoraFim, "00") & ":00:00"
		lineageTag: 56bec6e3-e3f2-4480-b512-a1cb7ba249da
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Dia da Semana' = ```
			
			VAR NomeCompleto = FORMAT('!DIM_CALENDARIO'[Date], "dddd")
			VAR NomeSemFeira = 
			    IF(
			        CONTAINSSTRING(NomeCompleto, "-"),
			        LEFT(NomeCompleto, FIND("-", NomeCompleto) - 1),
			        NomeCompleto
			    )
			RETURN UPPER(NomeSemFeira)
			
			
			
			
			```
		lineageTag: 37a98d1e-2e7d-4253-899f-1f98f5925849
		summarizeBy: none
		sortByColumn: 'Ordem Dia da Semana'

		annotation SummarizationSetBy = Automatic

	column 'Ordem Dia da Semana' =
			
			
			WEEKDAY('!DIM_CALENDARIO'[Date],1)
		formatString: 0
		lineageTag: 90b84cb3-58b2-446c-a2df-b23d1480ba6b
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Status Dia' = ```
			
			
			 
			VAR HJ = NOW() - 3/24
			VAR HOJE = DATE(YEAR(HJ),MONTH(HJ),DAY(HJ))
			
			RETURN
			
			
			IF('!DIM_CALENDARIO'[Date]=HOJE, "Dia Atual", FORMAT('!DIM_CALENDARIO'[Data],"dd/mm/yyyy"))
			```
		lineageTag: cf18cd42-ec6b-4adc-913a-e13785d4fd2e
		summarizeBy: none
		sortByColumn: Date

		annotation SummarizationSetBy = Automatic

	column 'Data Abrev' = FORMAT('!DIM_CALENDARIO'[Date], "DD/MM")
		lineageTag: 97a45780-be86-4ec8-a625-1e25867f94c4
		summarizeBy: none
		sortByColumn: Date

		annotation SummarizationSetBy = Automatic

	column Semana =
			
			IF(AND('!DIM_CALENDARIO'[Dia]>=1,'!DIM_CALENDARIO'[Dia]<=7),"SEMANA 1",
			    IF('!DIM_CALENDARIO'[Dia]<=14,"SEMANA 2",
			        IF('!DIM_CALENDARIO'[Dia]<=21,"SEMANA 3", "SEMANA 4")
			    )
			)
		lineageTag: eba81525-171a-43d0-a0c5-feda037b7857
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Dia = DAY('!DIM_CALENDARIO'[Data])
		formatString: 0
		lineageTag: c5b3959b-80ba-4e21-9775-89d3523fd9d3
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	partition !DIM_CALENDARIO = calculated
		mode: import
		source =
				
				VAR MinDateTime = DATE(2025,12,21)
				VAR MaxDateTime1 = SELECTEDVALUE('!DIM_ATUALIZAÇÃO'[Data e Hora Certa])+1
				VAR MaxDateTime = DATEVALUE(MaxDateTime1)
				VAR AdjustedMaxDateTime = MaxDateTime + TIME(0, 30, 0)
				RETURN
				    GENERATESERIES ( MinDateTime, AdjustedMaxDateTime, 30/1440 )

	annotation PBI_Id = b1a94bdbafa9493bb5e3b7b3ef463030

