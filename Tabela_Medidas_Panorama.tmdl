		sourceColumn: [Medida]

		annotation SummarizationSetBy = Automatic

	partition Tabela_Medidas_Panorama = calculated
		mode: import
		source = ```
				
				DATATABLE(
				    "Ordem", INTEGER,
				    "Medida", STRING,
				    {
				        { 1, "NS Projetado" },
				        { 2, "NS Realizado" },
				        { 3, "NS % Desvio" },
				        { 4, "Evolução NS Realizado" },
				        { 5, "Recebido Projetado" },
				        { 6, "Recebido Realizado" },
				        { 7, "Volume % Desvio" },
				        { 8, "Atendido Projetado" },
				        { 9, "Atendido Realizado" },
				        { 10, "% Desvio Atendido Projetado" },
				        { 11, "% Atendido" },
				        { 12, "Abandonadas" },
				        { 13, "% Abandono" },
				        { 14, "TMO Projetado" },
				        { 15, "TMO Realizado" },
				        { 16, "TMA Realizado" },
				        { 17, "TMO % Desvio" },
				        { 18, "Evolução TMO" }
				    }
				)
				
				```

