	column 'Semana no Mês Nomeada'
		lineageTag: fe76484f-d11a-4d4a-b01e-f1b586a33470
		summarizeBy: none
		isNameInferred
		sourceColumn: [Semana no Mês Nomeada]

		annotation SummarizationSetBy = Automatic

	partition Ultimos3MesesTabela = calculated
		mode: import
		source = ```
				
				VAR Hoje = TODAY()
				VAR PrimeiroDia3MesesAtras = EOMONTH(Hoje, -3) + 1
				VAR UltimoDiaMesAtual = EOMONTH(Hoje, 0)
				
				VAR TabelaFiltrada = 
				    FILTER(
				        '!DIM_CALENDARIO',
				        '!DIM_CALENDARIO'[Data] >= PrimeiroDia3MesesAtras &&
				        '!DIM_CALENDARIO'[Data] <= UltimoDiaMesAtual
				    )
				
				VAR TabelaComColunas =
				    ADDCOLUMNS(
				        TabelaFiltrada,
				        "Mês/Ano", 
				            UPPER(LEFT(FORMAT('!DIM_CALENDARIO'[Data], "mmm") & "/" & YEAR('!DIM_CALENDARIO'[Data]), 1)) & 
				            RIGHT(FORMAT('!DIM_CALENDARIO'[Data], "mmm") & "/" & YEAR('!DIM_CALENDARIO'[Data]), 7),
				
				        "Dia semana", 
				            SWITCH(
				                WEEKDAY('!DIM_CALENDARIO'[Data], 2),
				                1, "seg",
				                2, "ter",
				                3, "qua",
				                4, "qui",
				                5, "sex",
				                6, "sáb",
				                7, "dom"
				            ),
				
				        "Data com Dia Abrev", 
				            FORMAT('!DIM_CALENDARIO'[Data], "dd/MM") & "-" & 
				            SWITCH(
				                WEEKDAY('!DIM_CALENDARIO'[Data], 2),
				                1, "seg",
				                2, "ter",
				                3, "qua",
				                4, "qui",
				                5, "sex",
				                6, "sáb",
				                7, "dom"
				            ),
				
				        "OrdemData", '!DIM_CALENDARIO'[Data],
				        "DiaSemanaNum", WEEKDAY('!DIM_CALENDARIO'[Data], 2),
				
				        // Nova coluna - número da semana no mês
				        "SemanaNoMes", INT((DAY('!DIM_CALENDARIO'[Data]) - 1) / 7) + 1,
				
				        // Nova coluna - legenda da semana no mês no formato desejado
				        "Semana no Mês Nomeada",
				            VAR SemanaNumero = INT((DAY('!DIM_CALENDARIO'[Data]) - 1) / 7) + 1
				            VAR MesAno = FORMAT('!DIM_CALENDARIO'[Data], "MMM/yy")
				            RETURN FORMAT(SemanaNumero, "0º") & " - " & MesAno
				    )
				
				VAR TabelaResumo =
				    SUMMARIZE(
				        TabelaComColunas,
				        '!DIM_CALENDARIO'[Data],
				        [Mês/Ano],
				        [Dia semana],
				        [Data com Dia Abrev],
				        [OrdemData],
				        [DiaSemanaNum],
				        [SemanaNoMes],
				        [Semana no Mês Nomeada]
				    )
				
				RETURN
				    TabelaResumo
				
				```

	annotation PBI_Id = cc483055d30547cd88020364fd0a5960

