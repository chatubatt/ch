		sourceColumn: DMM ORDEM
		sortByColumn: DMM

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column 'DMM ORDEM Matriz' = ```
			
			VAR DMMValue = '@FT_FORECAST'[DMM]
			RETURN 
			SWITCH(TRUE(),
			    ISBLANK(DMMValue), BLANK(),
			    DMMValue < 10, "0" & DMMValue & "°",  // Adiciona zero para ordenação correta
			    DMMValue & "°"
			)
			```
		lineageTag: d3b790f2-c810-4d21-8d66-7b244cbb7113
