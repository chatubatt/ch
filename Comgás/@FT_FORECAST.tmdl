	column Fila =
			
			SWITCH(TRUE(),
			'@FT_FORECAST'[Celula] = "CONTAS", "FilaContas",
			'@FT_FORECAST'[Celula] = "ATENDIMENTO 08000", "FilaAtendimento08000",
			'@FT_FORECAST'[Celula] = "OUVIDORIA", "FilaOuvidoria",
			'@FT_FORECAST'[Celula] = "EMERGENCIA", "FilaEmergencialAcompanhamentoObras",
			"Outros"
			)
