	measure 'Evolução NS Realizado' = ```
			
			VAR ParamData = SELECTEDVALUE('Parâmetro_Data'[Parâmetro])
			
			VAR OrdemAtual = MAX('Ultimos3MesesTabela'[OrdemData])
			
			VAR ValorAtual = [NS Realizado]
			
			VAR ValorAnterior =
			    CALCULATE(
			        [NS Realizado],
			        FILTER(
			            ALL('Ultimos3MesesTabela'),
			            'Ultimos3MesesTabela'[OrdemData] = OrdemAtual - 1
			        )
			    )
			
			RETURN
			IF(
			    ValorAtual = 0 || ValorAtual = ValorAnterior || ISBLANK(ValorAnterior),
			    BLANK(),
			    DIVIDE(ValorAtual - ValorAnterior, ValorAnterior)
			)
			
			```
		displayFolder: Telefonia
		lineageTag: 3874f432-3c90-4650-a692-2a00368e894a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Evolução TMO' = ```
			
