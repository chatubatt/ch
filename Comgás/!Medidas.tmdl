	measure Tooltip_Analise = ```
			
			VAR Tipo = SELECTEDVALUE(Dim_Tooltip[TooltipID])
			VAR NS = [NS Realizado]
			VAR MetaNS = 0.9
			VAR Abandono = [%ABANDONADAS]
			VAR MetaAbandono = 0.05
			VAR TMO = [TMO]
			VAR MetaTMO = 542
			VAR Recebidas = [RECEBIDAS]
			VAR ForecastRecebidas = [@RECEBIDAS]
			VAR Atendidas = [ATENDIDAS]
			VAR ForecastAtendidas = [@ATENDIDAS]
			VAR PAsLogadas = [%PA]
			VAR ForecastPAs = [@PA]
			
			RETURN
			SWITCH(
			    TRUE(),
			
			    -- =========================
			    -- TOOLTIP NS
			    -- =========================
			    Tipo = "NS",
			        IF(
			            ISBLANK(NS),
			            "ℹ️ Nível de Serviço" & UNICHAR(10) &
			            "Sem dados suficientes para avaliação no período.",
			
			            SWITCH(
			                TRUE(),
			
			                NS >= MetaNS,
			                "🟢 Nível de Serviço dentro da meta" & UNICHAR(10) & UNICHAR(10) &
			                "O NS atual está em " & FORMAT(NS, "0.00%") &
			                ", acima da meta de 90,00%." & UNICHAR(10) &
			                "O tempo de espera está adequado para o cliente." & UNICHAR(10) &
			                "Recomendação: manter o dimensionamento atual.",
			
			                NS >= 0.85,
			                "🟡 Nível de Serviço em alerta" & UNICHAR(10) & UNICHAR(10) &
			                "O NS atual está em " & FORMAT(NS, "0.00%") &
			                ", abaixo da meta de 90,00%." & UNICHAR(10) &
			                "Há aumento perceptível no tempo de espera." & UNICHAR(10) &
			                "Recomendação: revisar escala e aderência.",
			
			                "🔴 Nível de Serviço crítico" & UNICHAR(10) & UNICHAR(10) &
			                "O NS atual está em " & FORMAT(NS, "0.00%") &
			                ", muito abaixo da meta de 90,00%." & UNICHAR(10) &
			                "Impacto direto na experiência do cliente." & UNICHAR(10) &
			                "Recomendação: reforçar atendimento imediatamente."
			            )
			        ),
			
			    -- =========================
			    -- TOOLTIP ABANDONO
			    -- =========================
			    Tipo = "ABANDONO",
			        IF(
			            ISBLANK(Abandono),
			            "ℹ️ Abandono" & UNICHAR(10) &
			            "Sem dados suficientes para avaliação no período.",
			
			            SWITCH(
			                TRUE(),
			
			                Abandono <= MetaAbandono,
			                "🟢 Abandono dentro da meta" & UNICHAR(10) & UNICHAR(10) &
			                "O abandono está em " & FORMAT(Abandono, "0.00%") &
			                ", dentro da meta operacional de até 5,00%." & UNICHAR(10) &
			                "O tempo de espera está adequado e a retenção é satisfatória." & UNICHAR(10) &
			                "Recomendação: manter o dimensionamento atual.",
			
			                Abandono <= 0.08,
			                "🟡 Abandono em nível de atenção" & UNICHAR(10) & UNICHAR(10) &
			                "O abandono está em " & FORMAT(Abandono, "0.00%") &
			                ", acima da meta de 5,00%." & UNICHAR(10) &
			                "Há indícios de aumento no tempo de espera ou filas." & UNICHAR(10) &
			                "Recomendação: revisar picos de demanda e aderência.",
			
			                "🔴 Abandono crítico" & UNICHAR(10) & UNICHAR(10) &
			                "O abandono está em " & FORMAT(Abandono, "0.00%") &
			                ", muito acima da meta de 5,00%." & UNICHAR(10) &
			                "Clientes estão desistindo antes do atendimento." & UNICHAR(10) &
			                "Recomendação: reforçar escala e priorizar filas críticas."
			            )
			        ),
			
			    -- =========================
			    -- TOOLTIP TMO
			    -- =========================
			    Tipo = "TMO",
			        IF(
			            ISBLANK(TMO),
			            "ℹ️ TMO" & UNICHAR(10) &
			            "Sem dados suficientes para avaliação no período.",
			
			            SWITCH(
			                TRUE(),
			
			                TMO <= MetaTMO,
			                "🟢 TMO dentro da meta" & UNICHAR(10) & UNICHAR(10) &
			                "O TMO está em " & FORMAT(TMO, "0") &
			                ", dentro da meta operacional de até " & MetaTMO & "." & UNICHAR(10) &
			                "O TMO está controlado e compatível com o forecast." & UNICHAR(10) &
			                "Recomendação: manter a eficiência e qualidade.",
			
			                TMO <= MetaTMO * 1.1,
			                "🟡 TMO em nível de atenção" & UNICHAR(10) & UNICHAR(10) &
			                "O TMO está em " & FORMAT(TMO, "0") &
			                ", acima da meta de " & MetaTMO & "." & UNICHAR(10) &
			                "Pode indicar dificuldade operacional ou falhas de script." & UNICHAR(10) &
			                "Recomendação: Monitorar causas.",
			
			                "🔴 TMO crítico" & UNICHAR(10) & UNICHAR(10) &
			                "O TMO está em " & FORMAT(TMO, "0") &
			                ", muito acima da meta de " & MetaTMO & "." & UNICHAR(10) &
			                "Impacto no NS e no Abandono." & UNICHAR(10) &
			                "Recomendação: Revisar processos, scripts, sistemas e capacitação."
			            )
			        ),
			
			    -- =========================
			    -- TOOLTIP VOLUME RECEBIDO
			    -- =========================
			    Tipo = "VOLUME_RECEBIDO",
			        IF(
			            ISBLANK(Recebidas),
			            "ℹ️ Volume Recebido" & UNICHAR(10) &
			            "Sem dados suficientes para avaliação no período.",
			
			            "📞 Volume Recebido" & UNICHAR(10) & UNICHAR(10) &
			            "Foram recebidas " & FORMAT(Recebidas, "0") & " chamadas no período." & UNICHAR(10) &
			            "O impacto operacional depende da capacidade disponível." & UNICHAR(10) &
			            "Recomendação: analisar em conjunto com NS, Abandono e PAs logadas."
			        ),
			
			    -- =========================
			    -- TOOLTIP VOLUME ATENDIDO
			    -- =========================
			    Tipo = "VOLUME_ATENDIDO",
			        IF(
			            ISBLANK(Atendidas),
			            "ℹ️ Volume Atendido" & UNICHAR(10) &
			            "Sem dados suficientes para avaliação no período.",
			
			            VAR TaxaAtendimento = DIVIDE(Atendidas, Recebidas)
			
			            RETURN
			            SWITCH(
			                TRUE(),
			
			                TaxaAtendimento >= 0.95,
			                "🟢 Volume Atendido adequado" & UNICHAR(10) & UNICHAR(10) &
			                FORMAT(Atendidas, "0") & " chamadas atendidas." & UNICHAR(10) &
			                "Alta taxa de absorção da demanda." & UNICHAR(10) &
			                "Recomendação: manter capacidade atual.",
			
			                TaxaAtendimento >= 0.90,
			                "🟡 Volume Atendido em atenção" & UNICHAR(10) & UNICHAR(10) &
			                FORMAT(Atendidas, "0") & " chamadas atendidas." & UNICHAR(10) &
			                "Parte da demanda não está sendo absorvida." & UNICHAR(10) &
			                "Recomendação: revisar escala e TMO.",
			
			                "🔴 Volume Atendido crítico" & UNICHAR(10) & UNICHAR(10) &
			                FORMAT(Atendidas, "0") & " chamadas atendidas." & UNICHAR(10) &
			                "Baixa capacidade frente à demanda." & UNICHAR(10) &
			                "Recomendação: reforçar PAs e reduzir tempo médio."
			            )
			        ),
			
			    -- =========================
			    -- TOOLTIP PAs LOGADAS
			    -- =========================
			    Tipo = "PAS",
			        IF(
			            ISBLANK(PAsLogadas),
			            "ℹ️ PAs Logadas" & UNICHAR(10) &
			            "Sem dados suficientes para avaliação no período.",
			
			            VAR AderenciaPA = DIVIDE(PAsLogadas, ForecastPAs)
			
			            RETURN
			            SWITCH(
			                TRUE(),
			
			                AderenciaPA >= 0.95,
			                "🟢 PAs dentro do planejado" & UNICHAR(10) & UNICHAR(10) &
			                FORMAT(PAsLogadas, "0") & " PAs logadas." & UNICHAR(10) &
			                "A escala está sendo cumprida adequadamente." & UNICHAR(10) &
			                "Recomendação: manter gestão atual.",
			
			                AderenciaPA >= 0.85,
			                "🟡 PAs em nível de atenção" & UNICHAR(10) & UNICHAR(10) &
			                FORMAT(PAsLogadas, "0") & " PAs logadas." & UNICHAR(10) &
			                "Déficit parcial de operadores." & UNICHAR(10) &
			                "Recomendação: verificar faltas, pausas e aderência.",
			
			                "🔴 PAs críticas" & UNICHAR(10) & UNICHAR(10) &
			                FORMAT(PAsLogadas, "0") & " PAs logadas." & UNICHAR(10) &
			                "Déficit severo de capacidade operacional." & UNICHAR(10) &
			                "Recomendação: acionar contingência e replanejar escala."
			            )
			        ),
			 
			
			    -- FALLBACK
			    "ℹ️ Indicador não identificado"
			)
			
			```
