	measure Comparativo_Recebidas_D-1 = ```
			
			VAR _DiaAtual =
			    CALCULATE(
			        MAX('!DIM_CALENDARIO'[Data]),
			        FILTER('!DIM_CALENDARIO', [Status Dia] = "Dia Atual")
			    )
			VAR _DiaAnterior = _DiaAtual - 1
			VAR _ValorAtual =
			    CALCULATE(
			        [RECEBIDAS],
			        FILTER(ALL('!DIM_CALENDARIO'), '!DIM_CALENDARIO'[Data] = _DiaAtual)
			    )
			VAR _ValorAnterior =
			    CALCULATE(
			        [RECEBIDAS],
			        FILTER(ALL('!DIM_CALENDARIO'), '!DIM_CALENDARIO'[Data] = _DiaAnterior)
			    )
			RETURN
			IF(
			    NOT ISBLANK(_ValorAtual) && NOT ISBLANK(_ValorAnterior),
			    DIVIDE(_ValorAtual, _ValorAnterior) - 1,
			    BLANK()
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Telefonia
		lineageTag: ef6ae9a3-dac4-4bcb-8a1f-0ea20c1ff400

