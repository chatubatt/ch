		sourceColumn: !DIM_CALENDARIO[Date]

		variation Variation
			isDefault
			relationship: 95ed9b7f-0106-466d-9d43-81dcc6598e16
			defaultHierarchy: LocalDateTable_2671bc84-3f9b-41e0-8d7f-3ae9cd18d006.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	partition Ultimos3MesesTabela* = calculated
		mode: import
		source = ```
				
				VAR Hoje = TODAY()
				VAR PrimeiroDia3MesesAtras = EOMONTH(Hoje, -3) + 1
				VAR UltimoDiaMesAtual = EOMONTH(Hoje, 0)
				
				VAR TabelaFiltrada = 
				    FILTER(
				        '!DIM_CALENDARIO',
				        '!DIM_CALENDARIO'[Date] >= PrimeiroDia3MesesAtras &&
				        '!DIM_CALENDARIO'[Date] <= UltimoDiaMesAtual
				    )
				
				VAR TabelaComColunas =
				    ADDCOLUMNS(
				        TabelaFiltrada,
				        "Mês/Ano", 
				            UPPER(LEFT(FORMAT('!DIM_CALENDARIO'[Date], "mmm") & "/" & YEAR('!DIM_CALENDARIO'[Date]), 1)) & 
				            RIGHT(FORMAT('!DIM_CALENDARIO'[Date], "mmm") & "/" & YEAR('!DIM_CALENDARIO'[Date]), 7),
				
				        "Dia semana", 
				            SWITCH(
				                WEEKDAY('!DIM_CALENDARIO'[Date], 2),
				                1, "seg",
				                2, "ter",
				                3, "qua",
				                4, "qui",
				                5, "sex",
				                6, "sáb",
				                7, "dom"
				            ),
				
				        "Data com Dia Abrev", 
				            FORMAT('!DIM_CALENDARIO'[Date], "dd/MM") & "-" & 
				            SWITCH(
				                WEEKDAY('!DIM_CALENDARIO'[Date], 2),
				                1, "seg",
				                2, "ter",
				                3, "qua",
				                4, "qui",
				                5, "sex",
				                6, "sáb",
				                7, "dom"
				            ),
				
				        "OrdemData", '!DIM_CALENDARIO'[Date],
				        "DiaSemanaNum", WEEKDAY('!DIM_CALENDARIO'[Date], 2),
				
				        // Nova coluna - número da semana no mês
				        "SemanaNoMes", INT((DAY('!DIM_CALENDARIO'[Date]) - 1) / 7) + 1,
				
				        // Nova coluna - legenda da semana no mês no formato desejado
				        "Semana no Mês Nomeada",
				            VAR SemanaNumero = INT((DAY('!DIM_CALENDARIO'[Date]) - 1) / 7) + 1
				            VAR MesAno = FORMAT('!DIM_CALENDARIO'[Date], "MMM/yy")
				            RETURN FORMAT(SemanaNumero, "0º") & " - " & MesAno
				    )
				
				VAR TabelaResumo =
				    SUMMARIZE(
				        TabelaComColunas,
				        '!DIM_CALENDARIO'[Date],
				        [Mês/Ano],
				        [Dia semana],
				        [Data com Dia Abrev],
				        [OrdemData],
				        [DiaSemanaNum],
				        [SemanaNoMes],
				        [Semana no Mês Nomeada]
				    )
				
				RETURN
				    TabelaResumo
				
				```

	annotation PBI_Id = 97c102f5d0aa40d689ce572656aebc52

