table TabelaTeste
	lineageTag: 0fd82b86-fffd-4705-8b4d-59771dc4b0a3

	column ROUTING_SKILL_NAME
		lineageTag: 61603831-5314-4a03-beef-c7b893ff196d
		summarizeBy: none
		isNameInferred
		sourceColumn: GENESYS_FT_PAUSAS[ROUTING_SKILL_NAME]

		annotation SummarizationSetBy = Automatic

	column starttime
		formatString: General Date
		lineageTag: f94aec4f-86f2-4122-a020-b988f3ed3779
		summarizeBy: none
		isNameInferred
		sourceColumn: GENESYS_FT_PAUSAS[starttime]

		variation Variation
			isDefault
			relationship: dfed931d-ec28-4570-b988-c3aebaefa1f5
			defaultHierarchy: LocalDateTable_39c4b96c-6343-4f76-b428-86aceb347789.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

	column 'CONTA PA'
		lineageTag: 969e8d46-1809-4ff9-93f0-e0111e3af43e
		summarizeBy: sum
		isNameInferred
		sourceColumn: GENESYS_FT_PAUSAS[CONTA PA]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition TabelaTeste = calculated
		mode: import
		source =
				
				UNION(
				    SUMMARIZE(
				        FILTER(
				            'GENESYS_FT_PAUSAS',
				            CONTAINSSTRING('GENESYS_FT_PAUSAS'[ROUTING_SKILL_NAME], "ContaPA")
				                && 'GENESYS_FT_PAUSAS'[ROUTING_SKILL_NAME] <> "ContaPAOuvidoria"
				        ),
				        'GENESYS_FT_PAUSAS'[ROUTING_SKILL_NAME],
				        'GENESYS_FT_PAUSAS'[starttime],
				        'GENESYS_FT_PAUSAS'[CONTA PA]
				    ),
				    SUMMARIZE(
				        FILTER(
				            'AVAYA_FT_TEMPOS',
				            CONTAINSSTRING('AVAYA_FT_TEMPOS'[routing_skill_name], "ContaPA")
				                && 'AVAYA_FT_TEMPOS'[routing_skill_name] <> "ContaPAOuvidoria"
				        ),
				        'AVAYA_FT_TEMPOS'[routing_skill_name],
				        'AVAYA_FT_TEMPOS'[starttime_a],
				        'AVAYA_FT_TEMPOS'[CONTA PA]
				    )
				)

	annotation PBI_Id = 415349d24e5c4c2bbeff9f565e731a74

