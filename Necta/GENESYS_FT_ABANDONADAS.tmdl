	column STATUS_ABNDONADAS = ```
			
			
			
			SWITCH(TRUE(),
			
			GENESYS_FT_ABANDONADAS[ABANDON_TIME] <= 5,       "Abandonada até 5",
			GENESYS_FT_ABANDONADAS[ABANDON_TIME] <= 10 ,     "Abandonada até 10",
			GENESYS_FT_ABANDONADAS[ABANDON_TIME] <= 15,      "Abandonada até 15",
			GENESYS_FT_ABANDONADAS[ABANDON_TIME] <= 20,      "Abandonada até 20",
			GENESYS_FT_ABANDONADAS[ABANDON_TIME] <= 25,      "Abandonada até 25",
			"Acima de 25")
			
			```
		lineageTag: 3c2ddf5c-e73e-4b1b-a853-a36e018ec3ef
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

