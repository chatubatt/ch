	column STATUS_ATENDIDAS = ```
			
			
			
			SWITCH(TRUE(),
			
			GENESYS_FT_ATENDIDAS[ANSWERED_TIME] <= 5,       "Atendidas até 5",
			GENESYS_FT_ATENDIDAS[ANSWERED_TIME] <= 10 ,     "Atendidas até 10",
			GENESYS_FT_ATENDIDAS[ANSWERED_TIME] <= 15,      "Atendidas até 15",
			GENESYS_FT_ATENDIDAS[ANSWERED_TIME] <= 20,      "Atendidas até 20",
			GENESYS_FT_ATENDIDAS[ANSWERED_TIME] <= 25,      "Atendidas até 25",
			"Acima de 25")
			
			```
		lineageTag: 32d4dd49-8bda-49d7-8bc9-d814d91234a5
		summarizeBy: none

